rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────────────────────

    function isLoggedIn() {
      return request.auth != null;
    }

    // IMPORTANT REQUIREMENT: ONLY ONE SUPER ADMIN UID
    function isSuperAdmin() {
      return isLoggedIn() && request.auth.uid == "mt0k0d3UeAgcB8RTzq5k3M97UKa2";
    }

    // ADMIN VERIFICATION USING ADMINS COLLECTION
    function isSameMadrasa(madrasaId) {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.madrasaId == madrasaId;
    }

    function isAuthorizedForMadrasa(madrasaId) {
       return isSuperAdmin() || isSameMadrasa(madrasaId);
    }

    // PARENT SESSION VERIFICATION
    function isParentOfStudent(studentId) {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/parent_sessions/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/parent_sessions/$(request.auth.uid)).data.studentId == studentId;
    }

    // ─── COLLECTION RULES ───────────────────────────────────────────────────

    // MADRASAS
    match /madrasas/{madrasaId} {
      // Public users can read basic madrasa info (needed for tracker selection)
      allow read: if true; 
      
      // Only Super Admin can create or delete madrasas
      allow create, delete: if isSuperAdmin();
      
      // Super admin or the specific madrasa admin can update it
      allow update: if isSuperAdmin() || isSameMadrasa(madrasaId); 
    }

    // ADMINS
    match /admins/{adminId} {
      // Admins can read their own doc, super admin can read all
      allow read: if isSuperAdmin() || (isLoggedIn() && request.auth.uid == adminId);
      
      // Only Super Admin can manage admins
      allow create, update, delete: if isSuperAdmin();
    }

    // PARENT SESSIONS
    match /parent_sessions/{userId} {
      allow read, write: if isLoggedIn() && request.auth.uid == userId;
    }

    // ADMISSION NUMBERS
    match /admission_numbers/{admissionNumber} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isSuperAdmin() || 
        (request.resource != null && isAuthorizedForMadrasa(request.resource.data.madrasaId)) ||
        (resource != null && isAuthorizedForMadrasa(resource.data.madrasaId));
    }

    // CLASSES
    match /classes/{classId} {
      allow read: if true; 
      allow create: if isAuthorizedForMadrasa(request.resource.data.madrasaId);
      allow update, delete: if isAuthorizedForMadrasa(resource.data.madrasaId);
    }

    // STUDENTS
    match /students/{studentId} {
      allow read: if isAuthorizedForMadrasa(resource.data.madrasaId)
                    || isParentOfStudent(studentId)
                    || (isLoggedIn() == false && resource.data.madrasaId != null);
      allow create: if isAuthorizedForMadrasa(request.resource.data.madrasaId);
      allow update, delete: if isAuthorizedForMadrasa(resource.data.madrasaId);
    }

    // SUBJECTS
    match /subjects/{subjectId} {
      allow read: if true; 
      allow create: if isAuthorizedForMadrasa(request.resource.data.madrasaId);
      allow update, delete: if isAuthorizedForMadrasa(resource.data.madrasaId);
    }

    // BOOKS
    match /books/{bookId} {
      allow read: if true; 
      allow create: if isAuthorizedForMadrasa(request.resource.data.madrasaId);
      allow update, delete: if isAuthorizedForMadrasa(resource.data.madrasaId);
    }

    // RECORDS (PRAYER TRACKING)
    match /records/{recordId} {
      allow read: if isAuthorizedForMadrasa(resource.data.madrasaId)
                    || isParentOfStudent(resource.data.studentId)
                    || (isLoggedIn() == false && resource.data.madrasaId != null);
      allow create: if true;
      allow update: if true;
      
      // Only Admins can delete records
      allow delete: if isAuthorizedForMadrasa(resource.data.madrasaId);
    }
  }
}
